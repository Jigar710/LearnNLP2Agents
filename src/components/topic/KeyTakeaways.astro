---
/**
 * KeyTakeaways (PRD §11.4 / Step 6.5) — rounded summary box with a phase-color
 * background (low opacity) and phase-color left border. Wrap a Markdown list;
 * its <li>s are restyled with checkmark bullets.
 */
interface Props {
  phase?: number;
  title?: string;
}
const { phase = 1, title = 'Key Takeaways' } = Astro.props;
---

<section class="key-takeaways" style={`--accent: var(--phase-${phase})`}>
  <h2 class="kt-title">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
    {title}
  </h2>
  <div class="kt-content"><slot /></div>
</section>

<style>
  .key-takeaways {
    margin: 2.5rem 0;
    padding: 1.25rem 1.5rem;
    border-radius: 12px;
    border-left: 4px solid var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }
  .kt-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 0.75rem;
    font-family: var(--font-sans);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
  }
  .kt-title svg {
    color: var(--accent);
  }
  .kt-content :global(ul) {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .kt-content :global(li) {
    position: relative;
    padding-left: 1.6rem;
    margin: 0.5rem 0;
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--text-primary);
  }
  .kt-content :global(li)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 0.6rem;
    height: 0.35rem;
    border-left: 2px solid var(--accent);
    border-bottom: 2px solid var(--accent);
    transform: rotate(-45deg);
  }
  .kt-content :global(strong) {
    color: var(--text-primary);
  }
</style>
