---
/**
 * Callout (PRD §11.3 / Step 6.4) — info / tip / warning / danger boxes.
 * Uses both an icon and color (never color alone) for accessibility.
 */
interface Props {
  type?: 'info' | 'tip' | 'warning' | 'danger';
  title?: string;
}
const { type = 'info', title } = Astro.props;

const CONFIG = {
  info: { color: 'var(--info)', bg: 'var(--callout-info-bg)', label: 'Note' },
  tip: { color: 'var(--success)', bg: 'var(--callout-tip-bg)', label: 'Tip' },
  warning: { color: 'var(--warning)', bg: 'var(--callout-warn-bg)', label: 'Warning' },
  danger: { color: 'var(--danger)', bg: 'var(--callout-danger-bg)', label: "Don't" },
} as const;
const c = CONFIG[type];
const heading = title ?? c.label;
---

<aside class:list={['callout', `callout-${type}`]} style={`--c: ${c.color}; --cbg: ${c.bg}`} role="note">
  <span class="callout-icon" aria-hidden="true">
    {type === 'info' && (
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
    )}
    {type === 'tip' && (
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6M10 22h4M12 2a7 7 0 0 0-4 12.7c.6.5 1 1.3 1 2.1h6c0-.8.4-1.6 1-2.1A7 7 0 0 0 12 2z"/></svg>
    )}
    {type === 'warning' && (
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0z"/><path d="M12 9v4M12 17h.01"/></svg>
    )}
    {type === 'danger' && (
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
    )}
  </span>
  <div class="callout-body">
    <p class="callout-title">{heading}</p>
    <div class="callout-content"><slot /></div>
  </div>
</aside>

<style>
  .callout {
    display: flex;
    gap: 0.75rem;
    margin: 1.5rem 0;
    padding: 0.9rem 1.1rem;
    border-radius: 8px;
    border-left: 3px solid var(--c);
    background: var(--cbg);
  }
  .callout-icon {
    flex-shrink: 0;
    color: var(--c);
    margin-top: 1px;
  }
  .callout-body {
    min-width: 0;
  }
  .callout-title {
    margin: 0 0 0.2rem;
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--c);
  }
  .callout-content {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--text-primary);
  }
  .callout-content :global(p) {
    margin: 0.4rem 0;
  }
  .callout-content :global(p:first-child) {
    margin-top: 0;
  }
  .callout-content :global(p:last-child) {
    margin-bottom: 0;
  }
  .callout-content :global(a) {
    color: var(--c);
    font-weight: 500;
    text-decoration: underline;
  }
  .callout-content :global(code) {
    font-size: 0.82em;
  }
</style>
