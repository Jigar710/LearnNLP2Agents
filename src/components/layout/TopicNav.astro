---
/**
 * TopicNav (PRD §10.6 [10] / Step 5.4) — previous / next topic navigation
 * shown at the bottom of every topic page. Phase-colored, with phase badge,
 * topic number, and title. (Named TopicNav to avoid clashing with the
 * site-wide Footer.astro.)
 */
import type { Topic } from '../../data/curriculum';
import { getPhaseColor } from '../../data/curriculum';
import { withBase } from '../../utils/base';

interface Props {
  prev?: Topic | null;
  next?: Topic | null;
}
const { prev, next } = Astro.props;

const num = (id: number) => String(id).padStart(2, '0');
---

<nav class="topic-nav" aria-label="Previous and next topic">
  {
    prev ? (
      <a class="nav-card prev" href={withBase(`/topic/${prev.slug}`)} style={`--accent: ${getPhaseColor(prev.phase)}`}>
        <span class="nav-dir">← Previous</span>
        <span class="nav-meta">Phase {prev.phase} · Topic {num(prev.id)}</span>
        <span class="nav-title">{prev.title}</span>
      </a>
    ) : (
      <span class="nav-spacer" />
    )
  }
  {
    next ? (
      <a class="nav-card next" href={withBase(`/topic/${next.slug}`)} style={`--accent: ${getPhaseColor(next.phase)}`}>
        <span class="nav-dir">Next →</span>
        <span class="nav-meta">Phase {next.phase} · Topic {num(next.id)}</span>
        <span class="nav-title">{next.title}</span>
      </a>
    ) : (
      <span class="nav-spacer" />
    )
  }
</nav>

<style>
  .topic-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
  }
  .nav-card {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.9rem 1.1rem;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    color: var(--text-primary);
    transition: border-color 150ms ease, background 150ms ease, transform 150ms ease;
  }
  .nav-card:hover {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 7%, transparent);
    transform: translateY(-1px);
    color: var(--text-primary);
  }
  .nav-card.next { text-align: right; align-items: flex-end; }
  .nav-dir {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
  }
  .nav-meta {
    font-size: 0.72rem;
    color: var(--text-muted);
  }
  .nav-title {
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.3;
  }
  .nav-spacer { display: block; }

  @media (max-width: 640px) {
    .topic-nav { grid-template-columns: 1fr; }
  }
</style>
