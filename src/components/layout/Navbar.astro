---
/**
 * Navbar (PRD §10.3) — fixed 60px top bar.
 * Left:  logo + phase quick-nav pills (hidden on mobile)
 * Center: search trigger (SearchModal island, opens on click or ⌘K)
 * Right: theme toggle, GitHub link, "Start Learning" CTA
 */
import Logo from './Logo.astro';
import ThemeToggle from '../ui/ThemeToggle.tsx';
import SearchModal from '../ui/SearchModal.tsx';
import { withBase } from '../../utils/base';

const GITHUB_URL = 'https://github.com/Jigar710/LearnNLP2Agents';
const START_SLUG = 'intro-to-nlp';
---

<header class="navbar" data-pagefind-ignore>
  <div class="navbar-left">
    <a href={withBase('/')} class="navbar-logo" aria-label="NLP to Agents — home">
      <Logo />
    </a>
  </div>

  <div class="navbar-center">
    <SearchModal client:load />
  </div>

  <div class="navbar-right">
    <ThemeToggle client:load />
    <a href={GITHUB_URL} class="icon-link" target="_blank" rel="noopener noreferrer" aria-label="GitHub repository">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.34-5.47-5.96 0-1.32.47-2.39 1.24-3.23-.13-.31-.54-1.53.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.65.25 2.87.12 3.18.77.84 1.24 1.91 1.24 3.23 0 4.63-2.81 5.65-5.49 5.95.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12.01 12.01 0 0 0 24 12.5C24 5.87 18.63.5 12 .5z" />
      </svg>
    </a>
    <a href={withBase(`/topic/${START_SLUG}`)} class="start-btn">Start Learning</a>
  </div>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 60px;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0 1.25rem;
    background: color-mix(in srgb, var(--bg-secondary) 90%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-color);
  }

  .navbar-left,
  .navbar-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
  }
  .navbar-right {
    justify-content: flex-end;
  }
  .navbar-center {
    flex: 0 1 auto;
  }
  .navbar-logo {
    color: inherit;
  }


  .icon-link {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    color: var(--text-secondary);
    transition: background 150ms ease, color 150ms ease;
  }
  .icon-link:hover {
    background: var(--code-bg-inline);
    color: var(--text-primary);
  }

  .start-btn {
    display: inline-flex;
    align-items: center;
    height: 36px;
    padding: 0 0.9rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    color: #fff;
    background: var(--accent, var(--phase-1));
    white-space: nowrap;
    transition: filter 150ms ease;
  }
  .start-btn:hover {
    filter: brightness(1.08);
    color: #fff;
  }

  @media (max-width: 900px) {
  @media (max-width: 640px) {
    .start-btn { display: none; }
    .navbar { padding: 0 0.85rem; }
  }
</style>

<!-- Theme-toggle & search-trigger styling (global so the React islands inherit it) -->
<style is:global>
  .theme-toggle {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    color: var(--text-secondary);
    background: transparent;
    transition: background 150ms ease, color 150ms ease, opacity 150ms ease;
  }
  .theme-toggle:hover {
    background: var(--code-bg-inline);
    color: var(--text-primary);
  }

  .search-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    width: min(400px, 40vw);
    height: 38px;
    padding: 0 0.75rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    background: var(--bg-primary);
    color: var(--text-muted);
    font-size: 0.875rem;
    cursor: pointer;
    transition: border-color 150ms ease;
  }
  .search-trigger:hover {
    border-color: color-mix(in srgb, var(--accent, var(--phase-1)) 50%, var(--border-color));
  }
  .search-trigger-text {
    flex: 1;
    text-align: left;
  }
  .search-kbd {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 1px 6px;
    border-radius: 5px;
    border: 1px solid var(--border-color);
    color: var(--text-muted);
  }
  @media (max-width: 640px) {
    .search-trigger { width: 38px; padding: 0; justify-content: center; }
    .search-trigger-text,
    .search-kbd { display: none; }
  }
</style>
