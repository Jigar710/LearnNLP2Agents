---
import BaseLayout from "../layouts/BaseLayout.astro";
import PhaseCard from "../components/home/PhaseCard.astro";
import { PHASES, TOTAL_TOPICS } from "../data/curriculum";
import { withBase } from "../utils/base";

const FEATURES = [
  {
    icon: "M4 19.5A2.5 2.5 0 0 1 6.5 17H20M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z",
    title: "In-depth Theory",
    desc: "Every concept explained from first principles — no hand-waving.",
  },
  {
    icon: "M16 18l6-6-6-6M8 6l-6 6 6 6",
    title: "Working Code",
    desc: "Runnable Python for every topic, with copy buttons.",
  },
  {
    icon: "M12 2v20M2 12h20",
    title: "Math Explained",
    desc: "KaTeX equations derived line by line where it matters.",
  },
  {
    icon: "M12 20a8 8 0 1 0 0-16 8 8 0 0 0 0 16zM12 8v4l3 2",
    title: "Interactive Demos",
    desc: "8 hands-on diagrams: attention, embeddings, agents, more.",
  },
  {
    icon: "M22 11.08V12a10 10 0 1 1-5.93-9.14M22 4 12 14.01l-3-3",
    title: "Progress Tracking",
    desc: "Mark topics complete; your place is saved locally.",
  },
  {
    icon: "M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22",
    title: "Open Source",
    desc: "Self-hosted, no accounts — clone the repo and run it anywhere.",
  },
];
const startHref = withBase("/topic/intro-to-nlp");
const curriculumHref = withBase("/curriculum");
---

<BaseLayout
  title="NLP to Agents — Learn NLP to Agentic AI, Beginner to Advanced"
  accent="var(--phase-1)"
>
  <!-- HERO -->
  <section class="hero">
    <h1 class="hero-title">
      Learn NLP to Agentic AI — <span class="hero-grad"
        >Beginner to Advanced</span>
    </h1>
    <p class="hero-tag">
      From a single token to a thinking agent — <span class="hl">learn</span>, <span
        class="hl">revise</span
      >, and master the entire journey of modern AI: NLP, Transformers, LLMs,
      RAG, and Agentic AI, all in one place.
    </p>
    <p class="hero-philo">
      “To teach a machine our language is to teach it to understand us.”
    </p>
    <div class="hero-cta">
      <a class="btn btn-primary" href={startHref}>Start Learning →</a>
      <a class="btn btn-ghost" href={curriculumHref}>View Curriculum</a>
      <a
        class="btn btn-ghost hero-resume"
        id="hero-resume"
        href={startHref}
        hidden>Resume Reading →</a
      >
    </div>
    <div class="hero-stats">
      <span><strong>{TOTAL_TOPICS}</strong> Topics</span>
      <span class="dot">·</span>
      <span><strong>{PHASES.length}</strong> Phases</span>
    </div>
  </section>

  <!-- PHASES -->
  <section class="home-section">
    <h2 class="home-h2">The Five-Phase Journey</h2>
    <p class="home-lead">
      Each phase builds on the last, taking you from tokenizing text to
      deploying production agents.
    </p>
    <div class="phase-grid">
      {PHASES.map((p) => <PhaseCard phase={p} />)}
    </div>
  </section>

  <!-- FEATURES -->
  <section class="home-section">
    <h2 class="home-h2">What You Get</h2>
    <div class="feature-grid">
      {
        FEATURES.map((f) => (
          <div class="feature-card">
            <span class="feature-icon" aria-hidden="true">
              <svg
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d={f.icon} />
              </svg>
            </span>
            <h3 class="feature-title">{f.title}</h3>
            <p class="feature-desc">{f.desc}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- CTA -->
  <section class="home-cta">
    <h2>Ready to start?</h2>
    <p>Begin with the NLP pipeline and work your way to autonomous agents.</p>
    <a class="btn btn-primary" href={startHref}>Start with Topic 1 →</a>
  </section>
</BaseLayout>

<style>
  .hero {
    max-width: 820px;
    margin: 0 auto;
    padding: 4.5rem 1.5rem 3rem;
    text-align: center;
  }
  .hero-title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(2.5rem, 7vw, 4rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
  }
  .hero-grad {
    background: linear-gradient(
      90deg,
      var(--phase-1),
      var(--phase-2) 40%,
      var(--phase-5)
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }
  .hero-tag {
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 62ch;
    margin: 0 auto 1.1rem;
  }
  .hero-tag .hl {
    color: var(--accent, var(--phase-1));
    font-weight: 700;
  }
  .hero-philo {
    font-size: 1.02rem;
    font-style: italic;
    line-height: 1.5;
    color: var(--accent, var(--phase-1));
    max-width: 52ch;
    margin: 0 auto 1.9rem;
    opacity: 0.92;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    justify-content: center;
    margin-bottom: 1.8rem;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.6rem 1.3rem;
    border-radius: 9999px;
    font-weight: 600;
    font-size: 0.92rem;
  }
  .btn-primary {
    background: var(--accent);
    color: #fff;
  }
  .btn-primary:hover {
    filter: brightness(1.08);
    color: #fff;
  }
  .btn-ghost {
    border: 1px solid var(--border-color);
    color: var(--text-primary);
  }
  .btn-ghost:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .hero-stats {
    display: flex;
    gap: 0.6rem;
    justify-content: center;
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  .hero-stats strong {
    color: var(--text-primary);
  }
  .hero-stats .dot {
    color: var(--border-color);
  }

  .home-section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem;
  }
  .home-h2 {
    font-size: 1.6rem;
    font-weight: 600;
    text-align: center;
    margin: 0 0 0.4rem;
  }
  .home-lead {
    text-align: center;
    color: var(--text-secondary);
    max-width: 60ch;
    margin: 0 auto 2rem;
  }
  .phase-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.1rem;
  }
  @media (max-width: 1000px) {
    .phase-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 640px) {
    .phase-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 420px) {
    .phase-grid {
      grid-template-columns: 1fr;
    }
  }
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.1rem;
  }
  .feature-card {
    padding: 1.3rem;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--bg-secondary);
  }
  .feature-icon {
    display: inline-grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 10px;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    margin-bottom: 0.7rem;
  }
  .feature-title {
    font-size: 1.02rem;
    font-weight: 600;
    margin: 0 0 0.3rem;
  }
  .feature-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.55;
    margin: 0;
  }

  .home-cta {
    max-width: 700px;
    margin: 1rem auto 4rem;
    padding: 2.5rem 1.5rem;
    text-align: center;
  }
  .home-cta h2 {
    font-family: var(--font-serif);
    font-size: 2rem;
    margin: 0 0 0.4rem;
  }
  .home-cta p {
    color: var(--text-secondary);
    margin: 0 0 1.3rem;
  }
</style>

<script>
  const KEY = "nlp2agents-last";
  const last = (() => {
    try {
      return localStorage.getItem(KEY);
    } catch {
      return null;
    }
  })();
  const btn = document.getElementById(
    "hero-resume",
  ) as HTMLAnchorElement | null;
  if (btn && last) {
    const base = import.meta.env.BASE_URL.replace(/\/$/, "");
    btn.href = `${base}/topic/${last}`;
    btn.hidden = false;
  }
</script>
